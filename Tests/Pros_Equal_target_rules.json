{
  "name": "Pros_Equal Targets",
  "description": "For diagram generation testing with Pros_Equal.dcm.",
  "include by default": false,
  "display by default": true,
  "skip_manual_selection": true,
  "rules": [
    {
      "id": "GTV-type",
      "description": "Select  GTV structures",
      "action": "include",
      "field": "Structure ID",
      "match_type": "regex",
      "value": ".*GTV.*"
    },
    {
      "id": "CTV-type",
      "description": "Select  CTV structures",
      "action": "include",
      "field": "DICOM Type",
      "match_type": "exact",
      "value": "CTV"
    },
    {
      "id": "PTV-type",
      "description": "Select  PTV structures",
      "action": "include",
      "field": "Structure ID",
      "match_type": "regex",
      "value": ".*PTV.*"
    },
    {
      "id": "CTV 48",
      "description": "exclude CTV 48",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "exact",
      "value": "CTV 48"
    }
  ]
}
