{
  "name": "Structure Relations Dev Environment",
  "image": "mcr.microsoft.com/vscode/devcontainers/anaconda:3",
  "postCreateCommand": "mkdir -p .vscode && cp -n .devcontainer/settings.json .vscode/settings.json && cp -n .devcontainer/DevCont.env .env && cp -n .devcontainer/StructureRelations.yml environment.yml && conda init && conda env create --name StructureRelations -f .devcontainer/StructureRelations.yml",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance",
        "hbenl.vscode-test-explorer",
        "LittleFoxTeam.vscode-python-test-adapter",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.isort",
        "VisualStudioExptTeam.vscodeintellicode",
        "streetsidesoftware.code-spell-checker",
        "ms-python.pylint",
        "ms-toolsai.datawrangler"
      ],
      "settings": {
        "python.envFile": "${workspaceFolder}/.env",
        "python.testing.pytestEnabled": true,
        "python.testing.nosetestsEnabled": false,
        "pythonTestExplorer.testFramework": "pytest",
        "python.defaultInterpreterPath": "/opt/conda/envs/StructureRelations/bin/python"
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/conda:2": {
      "addCondaForge": true,
      "installMiniconda": true,
      "condaVersion": "latest"
    }
  },
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "Structure Relations Webapp",
      "onAutoForward": "notify"
    }
  }
}
