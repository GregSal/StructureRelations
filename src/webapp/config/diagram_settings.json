{
  "description": "Configuration for network diagram visualization in StructureRelations webapp",
  "version": "1.0.0",
  "node_shapes": {
    "description": "Node shapes mapped to DICOM structure types for network diagram visualization. Valid shapes: star, hexagon, diamond, box, ellipse, triangle, triangleDown, dot, square",
    "shape_map": {
      "GTV": "ellipse",
      "CTV": "ellipse",
      "PTV": "ellipse",
      "EXTERNAL": "box",
      "ORGAN": "box",
      "AVOIDANCE": "box",
      "BOLUS": "box",
      "SUPPORT": "box",
      "FIXATION": "box"
    },
    "default_shape": "box"
  },
  "relationship_styles": {
    "description": "Line styles for relationship edges in network diagram",
    "UNKNOWN": {
      "color": "#999999",
      "width": 1,
      "dashes": true,
      "arrows": null
    },
    "DISJOINT": {
      "color": "#808080",
      "width": 1,
      "dashes": true,
      "arrows": null
    },
    "SHELTERS": {
      "color": "#9370DB",
      "width": 2,
      "dashes": true,
      "arrows": "to"
    },
    "SHELTERED": {
      "color": "#9370DB",
      "width": 2,
      "dashes": true,
      "arrows": "to"
    },
    "SURROUNDS": {
      "color": "#4169E1",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "ENCLOSED": {
      "color": "#4169E1",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "BORDERS": {
      "color": "#32CD32",
      "width": 3,
      "dashes": true,
      "arrows": null
    },
    "CONFINES": {
      "color": "#FF1493",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "CONFINED": {
      "color": "#FF1493",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "CONTAINS": {
      "color": "#00CED1",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "WITHIN": {
      "color": "#00CED1",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "EQUAL": {
      "color": "#FF0000",
      "width": 5,
      "dashes": false,
      "arrows": "to;from"
    },
    "PARTITIONED": {
      "color": "#FFD700",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "PARTITIONS": {
      "color": "#FFD700",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "OVERLAPS": {
      "color": "#FF6347",
      "width": 5,
      "dashes": false,
      "arrows": null
    }
  },
  "relationship_display_defaults": {
    "show_disjoint": false,
    "show_edge_labels": true,
    "logical_relations": "Limited",
    "show_unknown": false
  },
  "diagram_options": {
    "description": "Default options for network diagram visualization",
    "font": {
      "face": "Arial",
      "node_size": 14,
      "edge_size": 12,
      "dark_color": "#000000",
      "light_color": "#FFFFFF"
    },
    "background": {
      "color": "#000000"
    },
    "interaction": {
      "hover": true,
      "tooltip_delay": 100,
      "navigation_buttons": true,
      "keyboard": true
    },
    "diagram_layout": {
      "description": "Grouped layout and physics settings for interactive diagram positioning",
      "layout": {
        "improved_layout": true,
        "hierarchical": false,
        "local_global_default": 30,
        "local_global_min": 0,
        "local_global_max": 100
      },
      "physics": {
        "enabled": true,
        "stabilization_iterations": 200,
        "local": {
          "gravitational_constant": -700,
          "spring_constant": 0.008,
          "spring_length": 80,
          "damping": 0.55,
          "central_gravity": 0.02
        },
        "global": {
          "gravitational_constant": -2000,
          "spring_constant": 0.04,
          "spring_length": 150,
          "damping": 0.28,
          "central_gravity": 0.15
        }
      }
    }
  },
  "tooltips": {
    "description": "Controls which fields are shown in diagram tooltips. Set a field to false to hide it.",
    "nodes": {
      "show_roi_number": false,
      "show_type": true,
      "show_volume": true,
      "show_regions": true
    },
    "edges": {
      "show_structures": true,
      "relationship": "label",
      "show_direction": true,
      "show_logical": true,
      "show_description": true
    },
    "structure_set": {
      "show_structure_set": true,
      "show_structure_count": true,
      "show_file_name": true,
      "show_series_label": true,
      "show_patient_name": false,
      "show_patient_id": true,
      "show_resolution": true
    }
  }
}
