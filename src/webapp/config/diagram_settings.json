{
  "description": "Configuration for network diagram visualization in StructureRelations webapp",
  "version": "1.1.0",
  "node_shapes": {
    "description": "Node shapes mapped to DICOM structure types for network diagram visualization. Valid shapes: star, hexagon, diamond, box, ellipse, triangle, triangleDown, dot, square",
    "shape_map": {
      "GTV": "ellipse",
      "CTV": "ellipse",
      "PTV": "ellipse",
      "EXTERNAL": "box",
      "ORGAN": "box",
      "AVOIDANCE": "box",
      "BOLUS": "box",
      "SUPPORT": "box",
      "FIXATION": "box"
    },
    "default_shape": "box"
  },
  "relationship_styles": {
    "description": "Line styles for relationship edges in network diagram",
    "UNKNOWN": {
      "color": "#999999",
      "width": 1,
      "dashes": true,
      "arrows": null
    },
    "DISJOINT": {
      "color": "#808080",
      "width": 1,
      "dashes": true,
      "arrows": null
    },
    "SHELTERS": {
      "color": "#9370DB",
      "width": 2,
      "dashes": true,
      "arrows": "to"
    },
    "SHELTERED": {
      "color": "#9370DB",
      "width": 2,
      "dashes": true,
      "arrows": "to"
    },
    "SURROUNDS": {
      "color": "#4169E1",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "ENCLOSED": {
      "color": "#4169E1",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "BORDERS": {
      "color": "#32CD32",
      "width": 3,
      "dashes": true,
      "arrows": null
    },
    "CONFINES": {
      "color": "#FF1493",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "CONFINED": {
      "color": "#FF1493",
      "width": 3,
      "dashes": false,
      "arrows": "to"
    },
    "CONTAINS": {
      "color": "#00CED1",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "WITHIN": {
      "color": "#00CED1",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "EQUAL": {
      "color": "#FF0000",
      "width": 5,
      "dashes": false,
      "arrows": "to;from"
    },
    "PARTITIONED": {
      "color": "#FFD700",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "PARTITIONS": {
      "color": "#FFD700",
      "width": 4,
      "dashes": false,
      "arrows": "to"
    },
    "OVERLAPS": {
      "color": "#FF6347",
      "width": 5,
      "dashes": false,
      "arrows": null
    }
  },
  "relationship_display_defaults": {
    "show_disjoint": false,
    "show_edge_labels": true,
    "logical_relations": "Limited",
    "show_unknown": false
  },
  "diagram_options": {
    "description": "Default options for network diagram visualization",
    "font": {
      "face": "Arial",
      "node_size": 14,
      "edge_size": 12,
      "dark_color": "#000000",
      "light_color": "#FFFFFF"
    },
    "background": {
      "color": "#000000"
    },
    "interaction": {
      "hover": true,
      "tooltip_delay": 100,
      "navigation_buttons": true,
      "keyboard": true
    },
    "diagram_layout": {
      "description": "Grouped layout and physics settings for interactive diagram positioning",
      "layout": {
        "improved_layout": true,
        "hierarchical": false,
        "local_global_default": 30,
        "local_global_min": 0,
        "local_global_max": 100
      },
      "physics": {
        "enabled": true,
        "stabilization_iterations": 200,
        "local": {
          "gravitational_constant": -700,
          "spring_constant": 0.008,
          "spring_length": 80,
          "damping": 0.55,
          "central_gravity": 0.02
        },
        "global": {
          "gravitational_constant": -2000,
          "spring_constant": 0.04,
          "spring_length": 150,
          "damping": 0.28,
          "central_gravity": 0.15
        }
      }
    }
  },
  "tooltips": {
    "description": "Controls which fields are shown in diagram tooltips. Set a field to false to hide it.",
    "nodes": {
      "show_roi_number": false,
      "show_type": true,
      "show_volume": true,
      "show_regions": true
    },
    "edges": {
      "description": "Controls which relationship details appear in edge tooltips. Set 'relationship' to 'label' for the human-readable name, 'symbol' for the relationship symbol/notation, or 'type' for the internal relationship ID.",
      "show_structures": true,
      "relationship": "label",
      "show_direction": true,
      "show_logical": true,
      "show_description": true,
      "metrics": {
        "description": "Controls display of quantitative metrics for spatial relationships. Metrics must be calculated first using calculate_relationships(calculate_metrics=True). Only applicable metrics for each relationship type will be shown.",
        "enabled": true,
        "display_mode": "auto",
        "display_mode_options": {
          "auto": "Show most relevant metrics based on relationship type (1-3 metrics)",
          "compact": "Show only the single most critical metric (e.g., minimum margin)",
          "summary": "Show all aggregated 3D metrics (no per-slice data)",
          "detailed": "Show aggregated metrics plus key per-region breakdowns",
          "full": "Show all available metrics including per-slice and per-region data"
        },
        "show_units": true,
        "show_region_count": true,
        "show_worst_case_region": false,
        "margins": {
          "description": "Clearance distances inside containing structure. Applicable to CONTAINS, SURROUNDS, SHELTERS relationships.",
          "enabled": true,
          "show_orthogonal": true,
          "orthogonal_directions": {
            "description": "Which orthogonal margin directions to display. Options: 'all', 'worst', 'transverse', 'longitudinal', or list of specific directions.",
            "mode": "worst",
            "mode_options": {
              "worst": "Show only minimum margin (worst-case clearance)",
              "all": "Show all 6 directions (±X, ±Y, ±Z / ±LR, ±AP, ±SI)",
              "transverse": "Show in-plane directions only (±X, ±Y / ±LR, ±AP)",
              "longitudinal": "Show through-plane direction only (±Z / ±SI)",
              "custom": "Show specific directions listed in 'custom_directions'"
            },
            "custom_directions": ["x_neg", "x_pos", "y_neg", "y_pos", "z_neg", "z_pos"],
            "direction_labels": {
              "description": "How to label directions: 'anatomical' (R/L/A/P/S/I), 'geometric' (±X/±Y/±Z), or 'abbreviated' (+X/-X)",
              "mode": "anatomical",
              "anatomical_map": {
                "x_neg": "R",
                "x_pos": "L",
                "y_neg": "A",
                "y_pos": "P",
                "z_neg": "I",
                "z_pos": "S"
              }
            }
          },
          "show_minimum_margin": true,
          "show_maximum_margin": false,
          "highlight_below_threshold": false,
          "threshold_value": 0.5
        },
        "distance": {
          "description": "Gap between disjoint structures. Applicable to DISJOINT and SHELTERS relationships. N/A for BORDERS, CONFINES, EQUAL.",
          "enabled": true,
          "show_minimum_distance": true,
          "show_3d_components": false
        },
        "volume": {
          "description": "Volume overlap metrics. Applicable to OVERLAPS, PARTITION, CONTAINS, EQUAL relationships.",
          "enabled": true,
          "show_overlap_ratio": true,
          "show_dice_coefficient": false,
          "show_absolute_volumes": false,
          "ratio_basis": "auto",
          "ratio_basis_options": {
            "auto": "Use relationship-appropriate denominator (larger for PARTITION, average for OVERLAPS)",
            "larger": "Ratio relative to larger structure",
            "smaller": "Ratio relative to smaller structure",
            "average": "Ratio relative to average of both structures",
            "both": "Show both ratios (A/B and B/A)"
          }
        },
        "surface": {
          "description": "Surface boundary overlap metrics. Applicable to BORDERS and CONFINES relationships.",
          "enabled": true,
          "show_overlap_ratio": true,
          "show_absolute_areas": false,
          "show_overlap_length": false
        },
        "geometry": {
          "description": "Geometric properties of structures and their relationships.",
          "enabled": false,
          "show_centroid_distance": false,
          "show_centroid_coordinates": false
        },
        "formatting": {
          "decimal_places": 2,
          "scientific_notation_threshold": 1000,
          "show_na_as": "N/A",
          "show_zero_as": "0",
          "group_separator": ",",
          "compact_large_numbers": true
        },
        "per_region_display": {
          "description": "Controls display of per-region metric breakdowns for multi-region structures.",
          "enabled": false,
          "show_region_ids": true,
          "show_worst_case_only": true,
          "max_regions_shown": 3,
          "collapse_identical_values": true
        },
        "per_slice_display": {
          "description": "Controls display of per-slice metric data. Typically shown in detailed investigation view, not edge tooltips.",
          "enabled": false,
          "show_slice_range": true,
          "show_worst_slice": true,
          "max_slices_shown": 5
        }
      }
    },
    "structure_set": {
      "show_structure_set": true,
      "show_structure_count": true,
      "show_file_name": true,
      "show_series_label": true,
      "show_patient_name": false,
      "show_patient_id": true,
      "show_resolution": true
    }
  }
}
