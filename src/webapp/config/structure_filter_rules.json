{
  "name": "Default rules",
  "description": "Default structure selection rules for the webapp.",
  "include by default": true,
  "display by default": false,
  "skip_manual_selection": false,
  "rules": [
    {
      "id": "Z-Structures",
      "description": "Deselect helper or artifact structures (with a Z prefix)",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "Z"
    },
    {
      "id": "unreviewed-structures",
      "description": "Deselect unreviewed auto-contour structures (with a $ prefix)",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "$"
    },
    {
      "id": "resident-contours",
      "description": "Deselect resident structures (with an X prefix)",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "X"
    },
    {
      "id": "BOB-prefix",
      "description": "Exclude structures with the BOB prefix these are dose optimization structures.",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "BOB"
    },
    {
      "id": "Dose Structures",
      "description": "Exclude dose structures (e.g. D105).",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "regex",
      "value": "^D[0-9]+"
    },
    {
      "id": "Wires",
      "description": "Deselect wire structures (containing Wire)",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "regex",
      "value": ".*[wW]ire.*"
    },
    {
      "id": "support-structures",
      "description": "Deselect structures with Support type.",
      "action": "exclude",
      "field": "DICOM Type",
      "match_type": "exact",
      "value": "Support"
    },
    {
      "id": "Utility-structures",
      "description": "Exclude utility planning structures",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "structure list",
      "value": ["Baseline",
                "Matchplane",
                "CIED"
               ]
    },
    {
      "id": "Target-label",
      "description": "Select Target structures by their name",
      "action": "display",
      "field": "Structure ID",
      "match_type": "regex",
      "value": ".*[GCPIH]+TV.*"
    },
    {
      "id": "Target-type",
      "description": "Select Target DICOM types",
      "action": "display",
      "field": "DICOM Type",
      "match_type": "regex",
      "value": "[GCP]TV"
    }
  ]
}
