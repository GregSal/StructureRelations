{
  "name": "Default rules",
  "description": "Default structure selection rules for the webapp.",
  "include by default": true,
  "display by default": false,
  "skip_manual_selection": false,
  "rules": [
    {
      "id": "artifact-z-prefix",
      "description": "Deselect helper or artifact structures with a Z prefix",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "Z"
    },
    {
      "id": "helper-x-prefix",
      "description": "Deselect helper or temporary structures with an X prefix",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "X"
    },
    {
      "id": "dpv-prefix",
      "description": "Deselect structures with the DPV prefix",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "DPV"
    },
    {
      "id": "support-structures",
      "description": "Deselect structures with Support type.",
      "action": "exclude",
      "field": "DICOM Type",
      "match_type": "exact",
      "value": "Support"
    },
    {
      "id": "GTV-type",
      "description": "Select  GTV structures",
      "action": "display",
      "field": "Structure ID",
      "match_type": "regex",
      "value": ".*GTV.*"
    },
    {
      "id": "CTV-type",
      "description": "Select  CTV structures",
      "action": "display",
      "field": "DICOM Type",
      "match_type": "exact",
      "value": "CTV"
    },
    {
      "id": "PTV-type",
      "description": "Select  PTV structures",
      "action": "display",
      "field": "Structure ID",
      "match_type": "regex",
      "value": ".*PTV.*"
    }
  ]
}
