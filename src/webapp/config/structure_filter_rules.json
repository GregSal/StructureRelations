{
  "description": "Default automatic deselection rules for the structure picker",
  "version": "1.0.0",
  "rules": [
    {
      "id": "artifact-z-prefix",
      "description": "Deselect helper or artifact structures with a Z prefix",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "Z"
    },
    {
      "id": "helper-x-prefix",
      "description": "Deselect helper or temporary structures with an X prefix",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "X"
    },
    {
      "id": "dpv-prefix",
      "description": "Deselect structures with the DPV prefix",
      "action": "exclude",
      "field": "Structure ID",
      "match_type": "prefix",
      "value": "DPV"
    },
    {
      "id": "support-structures",
      "description": "Deselect structures with Support type.",
      "action": "exclude",
      "field": "DICOM Type",
      "match_type": "exact",
      "value": "Support"
    },
    {
      "id": "hide-oar",
      "description": "Hide OAR structures by default.",
      "action": "hide",
      "field": "DICOM Type",
      "match_type": "exact",
      "value": "ORGAN"
    }
  ]
}
